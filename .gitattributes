# Auto detect text files and perform LF normalization
* text=auto

# Python source files  always LF
*.py text eol=lf

# Config / docs  LF
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
LICENSE text eol=lf

# Binary files  no conversion
*.pt binary
*.pth binary
*.ckpt binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
